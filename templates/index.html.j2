<!doctype html>
<html lang="hu">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1" />
  <title>{{ title }}</title>

  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/reveal.js@5.1.0/dist/reset.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/reveal.js@5.1.0/dist/reveal.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/reveal.js@5.1.0/dist/theme/white.css" id="theme" />

  <style>
    :root { --fg: #1a1a1a; --muted: #666; }
    .reveal { font-family: "Inter", "Helvetica Neue", Arial, sans-serif; color: var(--fg); }
    .reveal h1, .reveal h2, .reveal h3 { text-transform: none; letter-spacing: 0; }
    .reveal section.title-slide h1 { font-size: 2.2em; margin-bottom: 0.2em; }
    .reveal section.title-slide .subtitle { color: var(--muted); font-size: 1.1em; }
    .reveal section.title-slide .meta { color: var(--muted); font-size: 0.8em; margin-top: 2em; }
    .reveal section.section-slide { background: #f4f4f2; }
    .reveal section.section-slide h2 { font-size: 2em; }

    .reveal section.toc-slide { text-align: left; }
    .reveal section.toc-slide h2 { font-size: 1.6em; margin-bottom: 0.6em; }
    .reveal .toc-section { font-weight: 600; font-size: 0.7em; margin: 0.6em 0 0.2em; color: var(--fg); }
    .reveal .toc-list { list-style: none; margin: 0; padding: 0; }
    .reveal .toc-list li { font-size: 0.55em; line-height: 1.8; }
    .reveal .toc-list li a { color: var(--muted); text-decoration: none; }
    .reveal .toc-list li a:hover { color: var(--fg); }

    .reveal figure { margin: 0 auto; max-width: 900px; width: 100%; display: flex; flex-direction: column; align-items: stretch; }
    .reveal figure .chart { flex: 1; min-height: 0; }
    .reveal figure .chart iframe { width: 100% !important; border: 0; }
    .reveal figure .chart img { max-width: 100%; max-height: 70vh; object-fit: contain; display: block; margin: 0 auto; }
    .reveal figure .figure-title { font-size: 0.7em; font-weight: 600; text-align: center; margin: 0 0 0.3em; }
    .reveal figure .figure-title .figure-number { color: var(--muted); }

    .topbar { position: fixed; top: 8px; right: 12px; z-index: 30; font: 13px/1 system-ui, sans-serif; }
    .topbar a { color: #555; text-decoration: none; padding: 4px 8px; border: 1px solid #ddd; border-radius: 4px; background: #fff; }
    .topbar a:hover { background: #f3f3f3; }
    @media print { .topbar { display: none; } }
  </style>
</head>
<body>
  <div class="topbar"><a href="print.html">Görgethető nézet ↦</a></div>

  <div class="reveal">
    <div class="slides">
      <section class="title-slide">
        <h1>{{ title }}</h1>
        {% if subtitle %}<div class="subtitle">{{ subtitle }}</div>{% endif %}
        <div class="meta">
          {% if author %}{{ author }}{% endif %}
          {% if author and date %} · {% endif %}
          {% if date %}{{ date }}{% endif %}
        </div>
      </section>

      <section class="toc-slide">
        <h2>Tartalom</h2>
        {% for f in figures %}
          {% if f.type == 'section' %}
            {% if not loop.first %}</ul>{% endif %}
        <div class="toc-section">{{ f.title }}</div>
        <ul class="toc-list">
          {% else %}
          <li><a href="#/{{ loop.index }}">{{ f.label }}{% if f.caption %} – {{ f.caption }}{% endif %}</a></li>
          {% endif %}
        {% endfor %}
        </ul>
      </section>

      {% for f in figures %}
        {% if f.type == 'section' %}
      <section class="section-slide"><h2>{{ f.title }}</h2></section>
        {% elif f.type == 'datawrapper' %}
      <section data-figure="{{ f.number }}">
        <figure>
          <h3 class="figure-title"><span class="figure-number">{{ f.label }}</span>{% if f.caption %} – {{ f.caption }}{% endif %}</h3>
          <div class="chart">
            <iframe title="{{ f.label }}" aria-label="{{ f.label }}"
                    id="datawrapper-chart-{{ f.chart_id }}-{{ f.number }}"
                    src="{{ f.src }}" scrolling="no" frameborder="0"
                    style="width:0; min-width:100% !important; border:none;"
                    height="{{ f.height }}" data-external="1"></iframe>
          </div>
        </figure>
      </section>
        {% elif f.type == 'image' %}
      <section data-figure="{{ f.number }}">
        <figure>
          <h3 class="figure-title"><span class="figure-number">{{ f.label }}</span>{% if f.caption %} – {{ f.caption }}{% endif %}</h3>
          <div class="chart"><img src="{{ f.src }}" alt="{{ f.alt }}" /></div>
        </figure>
      </section>
        {% endif %}
      {% endfor %}
    </div>
  </div>

  {% if has_datawrapper %}
  <script>
    /* Datawrapper auto-resize */
    window.addEventListener("message", function(event) {
      if (typeof event.data === "object" && event.data["datawrapper-height"]) {
        var heights = event.data["datawrapper-height"];
        for (var chartId in heights) {
          var iframe = document.getElementById("datawrapper-chart-" + chartId);
          if (!iframe) {
            /* Try matching by suffix pattern: datawrapper-chart-{id}-{number} */
            document.querySelectorAll("iframe[id^='datawrapper-chart-" + chartId + "']")
              .forEach(function(el) { el.style.height = heights[chartId] + "px"; });
          } else {
            iframe.style.height = heights[chartId] + "px";
          }
        }
      }
    });
  </script>
  {% endif %}

  <script src="https://cdn.jsdelivr.net/npm/reveal.js@5.1.0/dist/reveal.js"></script>
  <script>
    Reveal.initialize({
      hash: true,
      slideNumber: 'c/t',
      controls: true,
      progress: true,
      center: false,
      transition: 'slide',
      width: 1280,
      height: 900,
      margin: 0.02,
      pdfSeparateFragments: false,
    });
  </script>
</body>
</html>
